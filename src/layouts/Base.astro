---
import '../styles/styles.css';
import '../styles/app.css';
import { alternates, schemaGraph, SITE, urlFor } from '../lib/content.js';
import Consent from '../components/Consent.astro';

const { page, locale = 'en', theme = 'cream' } = Astro.props;
const canonical = urlFor(page.slug, locale);
const alts = alternates(page.slug);
const graph = schemaGraph(page, locale);
const ogImg = `https://qrcodeagent.net/assets/og/${page.slug || 'home'}.png`;
const ogType = page.archetype === 'article' ? 'article' : 'website';
const OG_LOCALE = {
  en: 'en_US', de: 'de_DE', es: 'es_ES', 'pt-br': 'pt_BR', fr: 'fr_FR', it: 'it_IT',
  ja: 'ja_JP', id: 'id_ID', uk: 'uk_UA', pl: 'pl_PL', ru: 'ru_RU',
};

// hreflang code doubles as the <html lang> value (SEO-BRIEF §8.1).
const htmlLang = alts.find((a) => a.href === canonical)?.hreflang || 'en';
const ogLocale = OG_LOCALE[locale] || 'en_US';

// Public env (client-safe) — set in Vercel. Empty locally = no-op.
const UMAMI = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
// Proxied via vercel.json → self-hosted Umami on Vercel (same team).
const UMAMI_SRC = import.meta.env.PUBLIC_UMAMI_SRC || '/stats/script.js';
const GA = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
---
<!DOCTYPE html>
<html lang={htmlLang} data-theme={theme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {/* Re-apply the visitor's saved theme before first paint. The site is static,
      so every navigation serves the default theme in the HTML; without this the
      chosen theme was lost on each page load. Must stay inline and render-
      blocking here — moving it into a module or the footer reintroduces a flash
      of the default theme. */}
  <script is:inline>
    try {
      var t = localStorage.getItem('qra:theme');
      if (t && t !== 'cream') document.documentElement.setAttribute('data-theme', t);
    } catch (e) {}
  </script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{page.title}</title>
  <meta name="description" content={page.meta} />
  <link rel="canonical" href={canonical} />
  {alts.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:title" content={page.title} />
  <meta property="og:description" content={page.meta} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={page.title} />
  <meta name="twitter:description" content={page.meta} />
  <meta name="twitter:image" content={ogImg} />
  <script type="application/ld+json" set:html={JSON.stringify(graph)} />

  {/* Umami — cookieless, primary analytics (no consent needed in most reads). */}
  {UMAMI && <script defer src={UMAMI_SRC} data-website-id={UMAMI}></script>}

  {/* GA4 — cookie-based, secondary: load only after consent (EU locales). */}
  {GA && (
    <script is:inline define:vars={{ GA }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function () { dataLayer.push(arguments); };
      window.loadGA = function () {
        if (window.__gaLoaded) return; window.__gaLoaded = true;
        var s = document.createElement('script');
        s.async = true; s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA;
        document.head.appendChild(s);
        gtag('js', new Date()); gtag('config', GA, { anonymize_ip: true });
      };
      // Consent gate: GA loads only on a stored 'granted'. Components/Consent.astro
      // asks when no decision exists and calls loadGA() on accept.
      try { if (localStorage.getItem('qra:consent') === 'granted') window.loadGA(); } catch (e) {}
    </script>
  )}
</head>
<body>
  <slot />
  <Consent locale={locale} />
</body>
</html>
