---
import Header from './Header.astro';
import Footer from './Footer.astro';
import Generator from './Generator.jsx';
import { SITE, labelFor, localHref, SUPPORT_URL } from '../lib/content.js';

const { page, locale = 'en' } = Astro.props;
const L = (href) => localHref(href, locale);   // locale-prefix internal links
const a = page.archetype;                       // home | feature | type | usecase | industry | learn | trust
const mode = (page.tool && page.tool.mode) || 'url';
// Every page type — QR types, use cases, ICP/industry, feature, home — embeds the
// exact generator widget. `guide` only changes the surrounding layout (breadcrumb,
// narrow hero, canonical callout), not whether the tool is present.
// `learn` is a content index and `trust` is prose (about/privacy) — neither embeds
// the tool: a privacy policy wrapped around a QR generator makes no sense.
const flagship = a !== 'learn' && a !== 'trust';
const guide = a === 'usecase' || a === 'industry';
const prose = a === 'trust';
const badge = a === 'usecase' ? 'Use-case guide' : a === 'industry' ? `For ${page.h1.replace(/^QR codes for /i, '')}` : a === 'learn' ? 'Learn' : a === 'trust' ? page.badge || 'About' : 'Free QR Codes';
const glyphs = ['✎', '◉', '∞', '⌂', '⚡', '◇', '✓'];
const canonical = guide && page.related ? page.related[0] : null;

// trust pills — exact folder set
const TRUST = [
  { i: '✓', b: 'Free forever', s: 'no sign-up' },
  { i: '∞', b: 'Never expires', s: 'static code' },
  { i: '⌂', b: 'In your browser', s: 'nothing uploaded' },
];
---
<Header locale={locale} slug={page.slug || ""} />

{guide && (
  <div class="wrap">
    <div class="crumb"><a href={L("/")}>Home</a> › <a>{a === 'usecase' ? 'Use cases' : 'By industry'}</a> › <span style="color:var(--ink-2);">{page.h1}</span></div>
  </div>
)}

<div class={guide ? 'wrap' : 'wrap hero'}>
  {guide ? (
    <div class="narrow hero left">
      <span class="badge">{badge}</span>
      <h1>{page.h1}</h1>
      {page.intro ? <p class="intro">{page.intro}</p> : page.subhead && <p class="intro">{page.subhead}</p>}
    </div>
  ) : (
    <>
      <span class="badge">{badge}</span>
      <h1>{page.h1}</h1>
      {page.subhead && <p class="sub">{page.subhead}</p>}
      {page.categories && (
        <div class="cats">{page.categories.map((c, i) => <span class={`cat${i === 0 ? ' on' : ''}`}>{c}</span>)}</div>
      )}
    </>
  )}
</div>

{/* learn hub — ported from ui_kits/website/learn.html. Article cards carry no
    href in the folder either; they stay unlinked until the articles exist, so
    the hub can ship without pointing at 404s. */}
{a === 'learn' && (
  <section class="blk"><div class="wrap">
    {page.featured && (
      <div class="feat">
        <div class="body">
          <span class="k">{page.featured.kicker}</span>
          <h3>{page.featured.title}</h3>
          <p>{page.featured.text}</p>
          <span class="meta">{page.featured.meta}</span>
        </div>
        <div class="art"><div class="stripe">ARTICLE COVER</div></div>
      </div>
    )}
    {page.articles && (
      <>
        <h2>{page.articles_title || 'Latest guides'}</h2>
        <div class="arts">
          {page.articles.map((art) => {
            const Tag = art.href ? 'a' : 'div';
            return (
              <Tag class="art-card" href={art.href ? L(art.href) : undefined}>
                <div class="thumb"><div class="s">COVER</div></div>
                <div class="c"><span class="k">{art.cat}</span><h4>{art.title}</h4><p>{art.text}</p><span class="meta">{art.meta}</span></div>
              </Tag>
            );
          })}
        </div>
      </>
    )}
    <div class="toolcta">
      <div><h3>Ready to make one?</h3><p>The generator is free, needs no sign-up, and your code never expires.</p></div>
      <a href={L('/')}>OPEN THE GENERATOR →</a>
    </div>
  </div></section>
)}

{/* trust prose (about / privacy) — reuses the existing narrow column and section
    rhythm; no new visual language, and no generator. */}
{prose && page.sections && (
  <section class="blk" style="padding-top:0;"><div class="wrap narrow">
    {page.sections.map((s) => (
      <div class="prose-sec">
        {s.h && <h2>{s.h}</h2>}
        {s.p && s.p.map((para) => <p>{para}</p>)}
        {s.list && <ul>{s.list.map((li) => <li>{li}</li>)}</ul>}
      </div>
    ))}
    {page.updated && <p class="prose-updated">Last updated {page.updated}</p>}
  </div></section>
)}

{flagship && (
  <div class="wrap tool-wrap"><div class="tool-scroll"><Generator client:load mode={mode} supportUrl={SUPPORT_URL} thanks={SITE.support.thankyou} /></div></div>
)}

{canonical && (
  <section class="blk" style="padding-top:26px;"><div class="wrap narrow">
    <div class="canon">
      <span class="k">Uses the</span>
      <h3>{labelFor(canonical, locale)} →</h3>
      <p>This guide reuses our dedicated generator — open it to enter your details and download a code that encodes the right payload.</p>
      <a class="cta" href={L(canonical)}>OPEN THE GENERATOR</a>
    </div>
  </div></section>
)}

{a === 'type' || a === 'home' ? (
  <section class="blk"><div class="wrap"><div class="trust">
    {TRUST.map((t) => <span class="tr"><i>{t.i}</i><b>{t.b}</b><small>{t.s}</small></span>)}
  </div></div></section>
) : null}

{page.howto && (
  <section class="blk" style="padding-top:0;"><div class={guide ? 'wrap narrow' : 'wrap'}>
    <h2>{page.howto.title}</h2>
    <div class="steps">
      {page.howto.steps.map((s, i) => <div class="step"><span class="num">{i + 1}</span><h4>{s.name}</h4><p>{s.text}</p></div>)}
    </div>
  </div></section>
)}

{page.benefits && !guide && (
  <section class="blk" style="padding-top:0;"><div class="wrap">
    <h2>Why it works</h2>
    <div class="bens">
      {page.benefits.map((b, i) => <div class="ben"><span class="bi">{glyphs[i % glyphs.length]}</span><h4>{b.h}</h4><p>{b.t}</p></div>)}
    </div>
  </div></section>
)}

{page.tools && (
  <section class="blk" style="padding-top:0;"><div class="wrap">
    <h2>The tools this ICP uses most</h2>
    <p class="lead">This is a hub — each card opens the dedicated free tool.</p>
    <div class="tools">
      {page.tools.map((t) => (
        <div class="tcard">
          <div class="top"><div class="qr"><canvas class="qrc" data-px="64" data-fg={t.fg} data-bg={t.bg} data-dot={t.dot} data-finder={t.finder} data-seed={t.seed}></canvas></div><div><h4>{t.name}</h4><div class="tag">{t.tag}</div></div></div>
          <p>{t.text}</p>
          <a class="go" href={L(t.href)}>{t.cta} →</a>
        </div>
      ))}
    </div>
  </div></section>
)}

{page.scenarios && (
  <section class="blk" style="padding-top:0;"><div class="wrap narrow">
    <h2>{page.scenarios_title || 'Where they put them'}</h2>
    <div class="scen">
      {page.scenarios.map((s) => <div class="card"><h4>{s.h}</h4><p>{s.t}</p></div>)}
    </div>
  </div></section>
)}

{page.directory && (
  <section class="blk" style="padding-top:0;"><div class="wrap dir">
    {page.directory.map((d) => (
      <div><div class="micro" style="margin-bottom:11px;">{d.heading}</div><div class="dchips">{d.links.map((h, i) => <a class={`dchip${i === 0 ? ' a' : ''}`} href={L(h)}>{labelFor(h, locale)}</a>)}</div></div>
    ))}
  </div></section>
)}

{page.related && (
  <section class="blk" style="padding-top:0;"><div class={guide ? 'wrap narrow' : 'wrap dir'}>
    <div><div class="micro" style="margin-bottom:11px;">{guide ? 'Related' : 'Related QR types'}</div><div class="dchips">{page.related.map((h, i) => <a class={`dchip${i === 0 && !guide ? ' a' : ''}`} href={L(h)}>{labelFor(h, locale)}</a>)}</div></div>
  </div></section>
)}

{page.faq && (
  <section class="blk" style="padding-top:0;"><div class={guide ? 'wrap narrow' : 'wrap'}>
    <h2>{page.h1} FAQ</h2>
    <div class="faq" style="margin-top:20px;">
      {page.faq.map((q, i) => (
        <details class="qa" open={i === 0}><summary class="q">{q.q}<span></span></summary><div class="a">{q.a}</div></details>
      ))}
    </div>
    <p class="thanks">Got your code? <a href={SUPPORT_URL} data-support="faq">☕ Buy me a coffee</a> — it keeps this tool free for everyone.</p>
  </div></section>
)}

<Footer locale={locale} />

{page.tools && (
  <script is:inline>
    // Decorative QR renderer for hub tool-card thumbnails — same logic as the
    // folder's qr-preview.js (ui_kits/website). Not used for scannable output.
    (function () {
      function drawQR(canvas) {
        const px = parseInt(canvas.dataset.px) || 64, dpr = 2; canvas.width = px * dpr; canvas.height = px * dpr;
        const ctx = canvas.getContext('2d'); ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        const fg = canvas.dataset.fg || '#000', bg = canvas.dataset.bg || '#fff', dot = canvas.dataset.dot || 'square', finder = canvas.dataset.finder || 'square';
        let s = (parseInt(canvas.dataset.seed) || 1) >>> 0; const rng = () => { s ^= s << 13; s ^= s >>> 17; s ^= s << 5; s >>>= 0; return s / 4294967296; };
        const N = 29, quiet = 2, total = N + quiet * 2, cell = px / total; ctx.fillStyle = bg; ctx.fillRect(0, 0, px, px); ctx.fillStyle = fg;
        const rr = (x, y, w, h, r) => { ctx.beginPath(); ctx.roundRect(x, y, w, h, r); ctx.fill(); };
        const inF = (r, c) => (r < 8 && c < 8) || (r < 8 && c >= N - 8) || (r >= N - 8 && c < 8);
        const mod = (r, c) => { const cx = (quiet + c + 0.5) * cell, cy = (quiet + r + 0.5) * cell, g = cell * 0.84, x = cx - g / 2, y = cy - g / 2;
          if (dot === 'circle') { ctx.beginPath(); ctx.arc(cx, cy, g / 2, 0, 7); ctx.fill(); }
          else if (dot === 'dot') { ctx.beginPath(); ctx.arc(cx, cy, g * 0.4, 0, 7); ctx.fill(); }
          else if (dot === 'diamond') { ctx.save(); ctx.translate(cx, cy); ctx.rotate(Math.PI / 4); ctx.fillRect(-g * 0.36, -g * 0.36, g * 0.72, g * 0.72); ctx.restore(); }
          else if (dot === 'rounded') { rr(x, y, g, g, g * 0.32); }
          else if (dot === 'star') { const t = g * 0.3; ctx.fillRect(cx - t / 2, cy - g / 2, t, g); ctx.fillRect(cx - g / 2, cy - t / 2, g, t); }
          else ctx.fillRect(x, y, g, g); };
        for (let r = 0; r < N; r++) for (let c = 0; c < N; c++) { if (inF(r, c)) continue; if (rng() > 0.52) mod(r, c); }
        const fin = (mr, mc) => { const x = (quiet + mc) * cell, y = (quiet + mr) * cell, s7 = 7 * cell, ccx = x + s7 / 2, ccy = y + s7 / 2;
          if (finder === 'circle') { ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(ccx, ccy, s7 / 2, 0, 7); ctx.fill(); ctx.fillStyle = bg; ctx.beginPath(); ctx.arc(ccx, ccy, s7 * 0.335, 0, 7); ctx.fill(); ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(ccx, ccy, s7 * 0.2, 0, 7); ctx.fill(); }
          else { const base = finder === 'cushion' ? s7 * 0.46 : finder === 'rounded' ? s7 * 0.28 : 0, rad = d => Math.max(0, base - d); ctx.fillStyle = fg; rr(x, y, s7, s7, rad(0)); ctx.fillStyle = bg; rr(x + cell, y + cell, s7 - 2 * cell, s7 - 2 * cell, rad(cell)); ctx.fillStyle = fg; rr(x + 2 * cell, y + 2 * cell, s7 - 4 * cell, s7 - 4 * cell, rad(2 * cell)); } ctx.fillStyle = fg; };
        fin(0, 0); fin(0, N - 7); fin(N - 7, 0);
      }
      document.querySelectorAll('canvas.qrc').forEach(drawQR);
    })();
  </script>
)}
