{
  "name": "qrcodeagent",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/gen-og.mjs && astro build && node scripts/gen-sitemap.mjs",
    "preview": "astro preview",
    "test": "node --test test/ src/lib/",
    "test:e2e": "playwright test",
    "verify": "npm test && npm run build && node scripts/check-build.mjs",
    "scan-sheet": "node scripts/scan-test-sheet.mjs",
    "i18n:extract": "node scripts/i18n-extract.mjs",
    "i18n:merge": "node scripts/i18n-merge.mjs",
    "i18n:coverage": "node scripts/i18n-coverage.mjs",
    "og": "node scripts/gen-og.mjs",
    "gsc:submit": "node scripts/gsc-submit.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^3.6.0",
    "astro": "^4.16.0",
    "qrcode-generator": "^1.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "jsqr": "^1.4.0",
    "wawoff2": "^2.0.1"
  }
}
